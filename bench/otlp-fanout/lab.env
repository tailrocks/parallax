# Source this to put your shell in compare mode against the lab's Rotel hub:
#   source bench/otlp-fanout/lab.env
# Then every `parallax run start -- <cmd>` forwards child telemetry to Rotel,
# which fans it out to every backend (incl. Parallax) for comparison.
export PARALLAX_OTLP_FORWARD=http://localhost:4317
export PARALLAX_ENV=lab
# Self-telemetry: make `parallax serve` also export its OWN spans/logs to Rotel
# (service.name=parallax), so Parallax's internals fan out beside the workload.
# The ingest receivers are suppressed from this exporter, so Rotel fanning back
# to Parallax (host.docker.internal:14317) cannot loop. Add `parallax` to
# Rotel's exporter lists (rotel.env) to receive the copy. Export this in the
# shell that runs `parallax serve`.
export PARALLAX_SELF_OTLP=http://localhost:4317
echo "compare mode ON — parallax run start now forwards to Rotel ($PARALLAX_OTLP_FORWARD)"
echo "self-telemetry ON — parallax serve exports its own spans/logs to Rotel ($PARALLAX_SELF_OTLP)"
