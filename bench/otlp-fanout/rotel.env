# Rotel fan-out configuration. Env names verified against streamfold/rotel-docs
# (2026-06-22); re-verify at the pinned Rotel version (pre-1.0, moves fast).

# Receivers: bind 0.0.0.0 so the container's published ports are reachable.
ROTEL_OTLP_GRPC_ENDPOINT=0.0.0.0:4317
ROTEL_OTLP_HTTP_ENDPOINT=0.0.0.0:4318

# --- Exporters -------------------------------------------------------------
# CORE lab = the two backends always present in the base compose: host Parallax
# + OpenObserve. SigNoz/Maple/Sentry are added when their overlays are running
# (uncomment them in both the declaration and the per-signal lists below).
ROTEL_EXPORTERS=parallax:otlp,openobserve:otlp
# Full lab:
# ROTEL_EXPORTERS=parallax:otlp,maple:otlp,signoz:otlp,openobserve:otlp,sentry:otlp

# Parallax — the only HOST sink → host.docker.internal. Offset gRPC port 14317.
ROTEL_EXPORTER_PARALLAX_ENDPOINT=http://host.docker.internal:14317
ROTEL_EXPORTER_PARALLAX_PROTOCOL=grpc

# OpenObserve — Compose service. gRPC :5081. Ingest REQUIRES auth + org/stream
# headers (Authorization = Basic base64(email:password)).
ROTEL_EXPORTER_OPENOBSERVE_ENDPOINT=http://openobserve:5081
ROTEL_EXPORTER_OPENOBSERVE_PROTOCOL=grpc
ROTEL_EXPORTER_OPENOBSERVE_CUSTOM_HEADERS=Authorization=Basic cm9vdEBleGFtcGxlLmNvbTpDb21wbGV4cGFzcyMxMjM=,organization=default,stream-name=default
ROTEL_EXPORTER_OPENOBSERVE_TLS_SKIP_VERIFY=true

# Maple — chDB-binary container (overlay compose.maple.yml). HTTP :4318, no auth.
ROTEL_EXPORTER_MAPLE_ENDPOINT=http://maple:4318
ROTEL_EXPORTER_MAPLE_PROTOCOL=http

# SigNoz — bundled otel-collector (overlay compose.signoz.yml). Service name is
# `otel-collector` (signoz-otel-collector is only its container_name).
ROTEL_EXPORTER_SIGNOZ_ENDPOINT=http://otel-collector:4317
ROTEL_EXPORTER_SIGNOZ_PROTOCOL=grpc

# Sentry (deferred phase) — OTLP/HTTP via nginx→relay. Project id + DSN public
# key come from a created Sentry project; fill in then restart Rotel.
# ROTEL_EXPORTER_SENTRY_ENDPOINT=http://nginx:80/api/<projectId>/integration/otlp
# ROTEL_EXPORTER_SENTRY_PROTOCOL=http
# ROTEL_EXPORTER_SENTRY_CUSTOM_HEADERS=x-sentry-auth=sentry sentry_key=<DSN public key>

# --- Per-signal fan-out (each listed exporter gets a copy) ------------------
# CORE:
ROTEL_EXPORTERS_TRACES=parallax,openobserve
ROTEL_EXPORTERS_LOGS=parallax,openobserve
ROTEL_EXPORTERS_METRICS=parallax,openobserve
# Full lab (Sentry omitted from METRICS — no OTLP metrics):
# ROTEL_EXPORTERS_TRACES=parallax,maple,signoz,openobserve,sentry
# ROTEL_EXPORTERS_LOGS=parallax,maple,signoz,openobserve,sentry
# ROTEL_EXPORTERS_METRICS=parallax,maple,signoz,openobserve
