{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tailrocks/parallax/schema/evidence-bundle.v0-poc.schema.json",
  "title": "parallax evidence bundle (bundle-v0-poc)",
  "description": "Reduced PoC shape of the evidence-bundle contract: anchor, typed nodes, typed strength-tagged edges, explicit missing evidence, redaction report, canonical hash. Draft PoC artifact; the production schema and its versioning policy are governed by the A3 schema gate.",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "generated_at_unix_nano",
    "generator",
    "project",
    "anchor",
    "trigger",
    "nodes",
    "edges",
    "hypotheses",
    "missing_evidence",
    "redaction_report",
    "canonical_hash"
  ],
  "properties": {
    "schema_version": { "const": "bundle-v0-poc" },
    "bundle_id": { "type": "string", "minLength": 1 },
    "generated_at_unix_nano": { "type": "string", "pattern": "^[0-9]+$" },
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "project": { "type": "string", "minLength": 1 },
    "anchor": {
      "type": "object",
      "required": ["type", "fingerprint", "service_name"],
      "properties": {
        "type": { "type": "string", "enum": ["issue", "run"] },
        "fingerprint": { "type": "string", "minLength": 1 },
        "service_name": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        {
          "properties": {
            "type": { "const": "issue" },
            "fingerprint": { "pattern": "^[0-9a-f]{16}$" }
          }
        },
        {
          "properties": {
            "type": { "const": "run" },
            "fingerprint": { "pattern": "^run_.+$" }
          }
        }
      ]
    },
    "trigger": {
      "type": "object",
      "required": ["type", "dispatch_eligible"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "new_fingerprint",
            "frequency_spike",
            "deploy_adjacent_regression",
            "fix_regression",
            "slo_breach",
            "manual"
          ]
        },
        "dispatch_eligible": { "type": "boolean" }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_type", "id"],
        "oneOf": [
          {
            "properties": { "node_type": { "const": "error_event" } },
            "required": [
              "node_type",
              "id",
              "source",
              "error_type",
              "message",
              "trace_id",
              "span_id",
              "time_unix_nano"
            ]
          },
          {
            "properties": { "node_type": { "const": "span" } },
            "required": [
              "node_type",
              "id",
              "name",
              "service_name",
              "trace_id",
              "span_id",
              "status_code",
              "duration_nano"
            ]
          },
          {
            "properties": { "node_type": { "const": "log_window" } },
            "required": ["node_type", "id", "trace_id", "lines"]
          },
          {
            "properties": { "node_type": { "const": "deploy" } },
            "required": [
              "node_type",
              "id",
              "release",
              "vcs_sha",
              "environment",
              "finished_at_unix_nano"
            ]
          },
          {
            "properties": { "node_type": { "const": "cli_invocation" } },
            "required": [
              "node_type",
              "id",
              "service_name",
              "command_line",
              "span_id"
            ]
          },
          {
            "properties": { "node_type": { "const": "agent_session" } },
            "required": [
              "node_type",
              "id",
              "tool",
              "repo",
              "vcs_sha",
              "started_at_unix_nano",
              "ended_at_unix_nano"
            ]
          },
          {
            "properties": { "node_type": { "const": "agent_action" } },
            "required": [
              "node_type",
              "id",
              "session_id",
              "seq",
              "action_type",
              "target",
              "detail"
            ]
          }
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "from", "to", "strength"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "strength": { "type": "string", "enum": ["strong", "medium", "weak", "inferred"] }
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "statement", "confidence", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": [
              "agent_change_regression",
              "deploy_regression",
              "dependency_failure",
              "insufficient_evidence"
            ]
          },
          "statement": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^(node|edge):" }
          }
        }
      }
    },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "redaction_report": {
      "type": "object",
      "required": ["policy_version", "redacted_counts"],
      "properties": {
        "policy_version": { "type": "string", "minLength": 1 },
        "redacted_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "canonical_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
